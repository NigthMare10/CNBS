{
  "name": "@cnbs/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:next": "node -e \"require('node:fs').rmSync('.next',{ recursive: true, force: true })\"",
    "build": "node -e \"require('node:fs').rmSync('.next',{ recursive: true, force: true })\" && next build",
    "dev": "node -e \"require('node:fs').rmSync('.next',{ recursive: true, force: true })\" && next dev --port 3000",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@cnbs/charts": "workspace:*",
    "@cnbs/config": "workspace:*",
    "@cnbs/domain": "workspace:*",
    "@cnbs/ui": "workspace:*",
    "@tanstack/react-table": "^8.21.2",
    "@vercel/analytics": "^2.0.1",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "next": "^15.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
